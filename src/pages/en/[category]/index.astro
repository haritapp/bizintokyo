---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';

export async function getStaticPaths() {
	return [
		{ params: { category: 'venue' } },
		{ params: { category: 'event' } },
		{ params: { category: 'eventguide' } },
		{ params: { category: 'news' } },
		{ params: { category: 'column' } },
	];
}

const { category } = Astro.params;

const titles: Record<string, string> = {
	venue: 'Venues',
	event: 'Events',
	eventguide: 'Event Guide',
	news: 'News',
	column: 'Columns',
};

const descriptions: Record<string, string> = {
	venue: 'Latest information on Tokyo\'s major business event venues.',
	event: 'Latest business events and exhibitions held in Tokyo.',
	eventguide: 'Practical guides to help you attend events in Tokyo.',
	news: 'The latest news from the events industry.',
	column: 'Columns and analysis on business events.',
};

const all = await getCollection(
	'articles',
	(e) => e.data.lang === 'en' && e.data.category === category,
);
all.sort((a, b) => +b.data.date - +a.data.date);
---

<BaseLayout
	title={`${titles[category!]} | BizinTokyo`}
	description={descriptions[category!]}
	lang="en"
>
	<div class="max-w-[1200px] mx-auto px-6 py-12">
		<h1 class="text-3xl font-bold mb-2">{titles[category!]}</h1>
		<p class="text-gray-600 mb-8">{descriptions[category!]}</p>
		{all.length > 0 ? (
			<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
				{all.map((article) => <ArticleCard article={article} />)}
			</div>
		) : (
			<p class="text-gray-500">Articles coming soon.</p>
		)}
	</div>
</BaseLayout>
