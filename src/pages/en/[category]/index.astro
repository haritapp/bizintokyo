---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import CategoryTabs from '../../../components/CategoryTabs.astro';
import Pagination from '../../../components/Pagination.astro';
import { CATEGORIES, PLACEHOLDER_CATEGORIES, t } from '../../../i18n';

export async function getStaticPaths() {
	return CATEGORIES.map((category) => ({ params: { category } }));
}

const lang = 'en';
const tr = t(lang);
const { category } = Astro.params;
const cat = category as (typeof CATEGORIES)[number];

const isPlaceholder = (PLACEHOLDER_CATEGORIES as readonly string[]).includes(cat);

const PER_PAGE = 12;
const all = isPlaceholder
	? []
	: await getCollection('articles', (e) => e.data.lang === lang && e.data.category === cat);
all.sort((a, b) => +b.data.date - +a.data.date);

const totalPages = Math.max(1, Math.ceil(all.length / PER_PAGE));
const items = all.slice(0, PER_PAGE);

const heading = tr.categoryHeadings[cat];
const subtitle = tr.categorySubtitles[cat];
const description = tr.categoryDescriptions[cat];
const title = tr.categoryTitles[cat];
---

<BaseLayout
	title={title}
	description={description}
	lang={lang}
	breadcrumb={[
		{ name: tr.meta.breadcrumbHome, href: '/en/' },
		{ name: heading },
	]}
>
	<div class="max-w-[1200px] mx-auto px-6 py-8">
		<Breadcrumbs items={[
			{ name: tr.meta.breadcrumbHome, href: '/en/' },
			{ name: heading },
		]} />
	</div>

	<section class="max-w-[1200px] mx-auto px-6 pb-12">
		<p class="text-[12px] tracking-[0.3em] text-[#6B6B6B] uppercase font-medium">{subtitle}</p>
		<h1 class="text-3xl md:text-5xl font-light text-[#1A1A1A] mt-3 tracking-tight">{heading}</h1>
		<p class="text-[#6B6B6B] mt-6 max-w-3xl leading-relaxed font-light">{description}</p>
	</section>

	<CategoryTabs current={cat} lang={lang} />

	<section class="max-w-[1200px] mx-auto px-6 py-16">
		{isPlaceholder ? (
			<div class="border border-[#E5E5E5] py-20 text-center">
				<p class="text-[12px] tracking-[0.3em] text-[#6B6B6B] uppercase font-medium">{tr.meta.comingSoon}</p>
				<p class="mt-4 text-[#1A1A1A] font-light">{tr.meta.comingSoonBody}</p>
			</div>
		) : items.length > 0 ? (
			<>
				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
					{items.map((a) => <ArticleCard article={a} />)}
				</div>
				<Pagination current={1} total={totalPages} baseHref={`/en/${cat}`} lang={lang} />
			</>
		) : (
			<div class="border border-[#E5E5E5] py-20 text-center">
				<p class="text-[12px] tracking-[0.3em] text-[#6B6B6B] uppercase font-medium">{tr.meta.comingSoon}</p>
				<p class="mt-4 text-[#1A1A1A] font-light">{tr.meta.comingSoonBody}</p>
			</div>
		)}
	</section>
</BaseLayout>
