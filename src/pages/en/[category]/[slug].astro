---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import AuthorBio from '../../../components/AuthorBio.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import TOC from '../../../components/TOC.astro';
import { authors } from '../../../config/authors';
import { ARTICLE_CATEGORIES, t } from '../../../i18n';

export async function getStaticPaths() {
	const articles = await getCollection('articles', (e) => e.data.lang === 'en');
	return articles.map((article) => ({
		params: { category: article.data.category, slug: article.data.slug },
		props: { article },
	}));
}

const { article } = Astro.props;
const { Content, headings } = await render(article);
const { title, date, updated, category, description, heroImage, ogImage, isPR, slug, author, template } = article.data;

const lang = 'en';
const tr = t(lang);

const formatDate = (d: Date) =>
	`${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
const publishedStr = formatDate(date);
const updatedStr = updated ? formatDate(updated) : null;

const categoryLabel = tr.categoryHeadings[category as (typeof ARTICLE_CATEGORIES)[number]];

const allInCategory = await getCollection(
	'articles',
	(e) => e.data.lang === lang && e.data.category === category && e.data.slug !== slug,
);
allInCategory.sort((a, b) => +b.data.date - +a.data.date);
const related = allInCategory.slice(0, 4);

const jaMatches = await getCollection(
	'articles',
	(e) => e.data.lang === 'ja' && e.data.slug === slug && e.data.category === category,
);
const switchHref = jaMatches.length > 0 ? `/${category}/${slug}` : '/';

const authorInfo = authors[author];
const authorName = authorInfo.nameEn;

const site = Astro.site?.toString().replace(/\/$/, '') || 'https://bizintokyo.com';
const articleUrl = `${site}/en/${category}/${slug}`;

const showToc = template === 'guide' || (template === 'standard' && headings.filter((h) => h.depth === 2 || h.depth === 3).length >= 3);
const showAuthorBio = template !== 'event';
---

<BaseLayout
	title={`${title} | ${categoryLabel} | BizinTokyo`}
	description={description}
	lang={lang}
	ogImage={ogImage || heroImage}
	articleData={{
		headline: title,
		datePublished: date.toISOString(),
		dateModified: updated ? updated.toISOString() : date.toISOString(),
		image: heroImage || ogImage,
		authorName,
	}}
	breadcrumb={[
		{ name: tr.meta.breadcrumbHome, href: '/en/' },
		{ name: categoryLabel, href: `/en/${category}` },
		{ name: title },
	]}
>
	<article class="max-w-3xl mx-auto px-6 py-10">
		<Breadcrumbs items={[
			{ name: tr.meta.breadcrumbHome, href: '/en/' },
			{ name: categoryLabel, href: `/en/${category}` },
			{ name: title },
		]} />

		<div class="mt-10">
			<a href={`/en/${category}`} class="text-[12px] tracking-[0.25em] text-[#1D4F91] uppercase no-underline hover:text-[#153A6B] font-medium">{categoryLabel}</a>
			{isPR && <span class="ml-3 inline-block px-2 py-0.5 border border-[#1D4F91] text-[10px] text-[#1D4F91] tracking-wider">PR</span>}
		</div>

		<h1 class="mt-5 text-[32px] md:text-[48px] lg:text-[52px] font-light text-[#1A1A1A] leading-[1.25] tracking-[-0.02em]">{title}</h1>

		<div class="mt-7 text-[13px] text-[#6B6B6B] tracking-wider font-normal flex flex-wrap items-center gap-x-5 gap-y-2">
			<span>{tr.meta.author}: {authorName}</span>
			<span>{tr.meta.published}: {publishedStr}</span>
			{updatedStr && <span>{tr.meta.updated}: {updatedStr}</span>}
		</div>

		<div class="mt-6">
			<ShareButtons url={articleUrl} title={title} lang={lang} />
		</div>

		{heroImage && (
			<figure class="mt-10 aspect-video bg-[#FAFAF7] overflow-hidden">
				<img src={heroImage} alt={title} class="w-full h-full object-cover" />
			</figure>
		)}

		<p class="mt-10 text-[#1A1A1A] text-[18px] md:text-[19px] font-normal leading-[1.85]">{description}</p>

		{showToc && <TOC headings={headings} lang={lang} minHeadings={template === 'guide' ? 1 : 3} />}

		<div class="prose-bizin mt-10">
			<Content />
		</div>

		<div class="mt-12 pt-6 border-t border-[#E5E5E5]">
			<ShareButtons url={articleUrl} title={title} lang={lang} />
		</div>

		{showAuthorBio && <AuthorBio authorKey={author} lang={lang} />}

		<div class="mt-10 text-[12px] tracking-wider">
			<a href={switchHref} class="text-[#1D4F91] hover:text-[#153A6B] no-underline">日本語版 →</a>
		</div>
	</article>

	{related.length > 0 && (
		<section class="bg-[#FAFAF7] border-t border-[#E5E5E5] py-20 md:py-28 mt-16">
			<div class="max-w-[1200px] mx-auto px-6">
				<div class="flex items-stretch gap-5 mb-12">
					<div class="w-[3px] bg-[#1D4F91]" aria-hidden="true"></div>
					<div>
						<p class="text-[12px] tracking-[0.22em] text-[#6B6B6B] uppercase font-medium">{tr.meta.relatedArticles}</p>
						<h2 class="text-[28px] md:text-[36px] font-normal text-[#1A1A1A] mt-2 tracking-[-0.01em]">Related Articles</h2>
					</div>
				</div>
				<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-7 md:gap-8">
					{related.map((r) => <ArticleCard article={r} />)}
				</div>
			</div>
		</section>
	)}
</BaseLayout>
