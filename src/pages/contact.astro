---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact | BizinTokyo" description="BizinTokyoへのお問い合わせフォーム" lang="ja">
	<div class="max-w-2xl mx-auto py-12 px-6">
		<h1 class="text-3xl font-bold mb-6">Contact</h1>
		<form
			action="https://formspree.io/f/YOUR_FORM_ID"
			method="POST"
			class="bg-white border border-gray-200 rounded-lg p-6 space-y-4 shadow-sm"
		>
			<div>
				<label class="block text-sm font-bold mb-1">お名前 <span class="text-red-500">*</span></label>
				<input type="text" name="name" required class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand" />
			</div>
			<div>
				<label class="block text-sm font-bold mb-1">メールアドレス <span class="text-red-500">*</span></label>
				<input type="email" name="email" required class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand" />
			</div>
			<div>
				<label class="block text-sm font-bold mb-1">会社名</label>
				<input type="text" name="company" class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand" />
			</div>
			<div>
				<label class="block text-sm font-bold mb-1">種別</label>
				<select name="type" class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand">
					<option>会場予約相談</option>
					<option>メディア掲載</option>
					<option>その他</option>
				</select>
			</div>
			<div>
				<label class="block text-sm font-bold mb-1">内容 <span class="text-red-500">*</span></label>
				<textarea name="message" rows="6" required class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand"></textarea>
			</div>
			<button type="submit" class="bg-brand text-white px-6 py-2 rounded hover:opacity-90 font-bold">送信</button>
		</form>
	</div>
</BaseLayout>
