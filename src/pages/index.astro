---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { featuredArticles } from '../config/featured';
import { ARTICLE_CATEGORIES, t } from '../i18n';

const lang = 'ja';
const tr = t(lang);

const all = await getCollection('articles', (e) => e.data.lang === lang);
all.sort((a, b) => +b.data.date - +a.data.date);

const featured = featuredArticles
	.map((f) => all.find((a) => a.data.slug === f.slug && a.data.category === f.category))
	.filter((a): a is NonNullable<typeof a> => Boolean(a));

const sections = ARTICLE_CATEGORIES.map((c) => ({
	category: c,
	label: tr.categoryHeadings[c],
	subtitle: tr.categorySubtitles[c],
	items: all.filter((a) => a.data.category === c).slice(0, 3),
}));
---

<BaseLayout
	title="BizinTokyo - 東京のビジネスイベントを、もっと深く、もっとスマートに"
	description="訪日ビジネストラベラー・イベント参加者のための、東京ビジネスイベント情報メディア。会場・イベント・ホテル・ガイドを発信します。"
	lang={lang}
>
	<Hero lang={lang} />

	{featured.length > 0 && (
		<section class="max-w-[1200px] mx-auto px-6 py-24 md:py-32">
			<SectionHeading
				title="編集部のおすすめ"
				subtitle="Editor's Picks"
			/>
			<div class="grid md:grid-cols-2 gap-7 md:gap-10">
				{featured.map((a) => <ArticleCard article={a} size="large" />)}
			</div>
		</section>
	)}

	{sections.filter((s) => s.items.length > 0).map((s) => (
		<section class="max-w-[1200px] mx-auto px-6 py-20 md:py-28 border-t border-[#E5E5E5]">
			<SectionHeading
				title={s.label}
				subtitle={s.subtitle}
				viewAll={{ href: `/${s.category}`, label: tr.meta.viewAll }}
			/>
			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-7 md:gap-8">
				{s.items.map((a) => <ArticleCard article={a} />)}
			</div>
		</section>
	))}

	<section class="bg-[#FAFAF7] border-t border-[#E5E5E5] py-24 md:py-32">
		<div class="max-w-[1200px] mx-auto px-6 text-center">
			<p class="text-[12px] tracking-[0.4em] text-[#1D4F91] uppercase font-medium mb-6">About BizinTokyo</p>
			<h2 class="text-[28px] md:text-[36px] font-light text-[#1A1A1A] leading-[1.4] max-w-3xl mx-auto tracking-[-0.01em]">
				東京のビジネスイベントを、訪日トラベラーへ。
			</h2>
			<p class="mt-8 text-[16px] md:text-[17px] text-[#1A1A1A] leading-[1.9] max-w-2xl mx-auto font-normal">
				会場・アクセス・周辺ホテル・イベントガイドまで、現地で本当に役立つ情報を、日本語と英語の両方で発信します。
			</p>
			<div class="mt-10">
				<a href="/contact" class="btn-outline">お問い合わせ <span aria-hidden="true">→</span></a>
			</div>
		</div>
	</section>
</BaseLayout>
