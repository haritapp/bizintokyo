---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { featuredArticles } from '../config/featured';
import { ARTICLE_CATEGORIES, t } from '../i18n';

const lang = 'ja';
const tr = t(lang);

const all = await getCollection('articles', (e) => e.data.lang === lang);
all.sort((a, b) => +b.data.date - +a.data.date);

const featured = featuredArticles
	.map((f) => all.find((a) => a.data.slug === f.slug && a.data.category === f.category))
	.filter((a): a is NonNullable<typeof a> => Boolean(a));

const sections = ARTICLE_CATEGORIES.map((c) => ({
	category: c,
	label: tr.categoryHeadings[c],
	subtitle: tr.categorySubtitles[c],
	items: all.filter((a) => a.data.category === c).slice(0, 3),
}));
---

<BaseLayout
	title="BizinTokyo - 東京のビジネスイベントを、もっと深く、もっとスマートに"
	description="訪日ビジネストラベラー・イベント参加者のための、東京ビジネスイベント情報メディア。会場・イベント・ホテル・ガイドを発信します。"
	lang={lang}
>
	<Hero lang={lang} />

	{featured.length > 0 && (
		<section class="max-w-[1200px] mx-auto px-6 py-24 md:py-32">
			<SectionHeading
				title="編集部のおすすめ"
				subtitle="Editor's Picks"
			/>
			<div class="grid md:grid-cols-2 gap-7 md:gap-10">
				{featured.map((a) => <ArticleCard article={a} size="large" />)}
			</div>
		</section>
	)}

	{sections.filter((s) => s.items.length > 0).map((s) => (
		<section class="max-w-[1200px] mx-auto px-6 py-20 md:py-28 border-t border-[#E5E5E5]">
			<SectionHeading
				title={s.label}
				subtitle={s.subtitle}
				viewAll={{ href: `/${s.category}`, label: tr.meta.viewAll }}
			/>
			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-7 md:gap-8">
				{s.items.map((a) => <ArticleCard article={a} />)}
			</div>
		</section>
	))}

	<section class="bg-[#F5F2EA] border-t border-[#E5E5E5] py-28 md:py-40">
		<div class="max-w-[1200px] mx-auto px-6 text-center">
			<p class="text-[13px] md:text-[14px] tracking-[0.4em] text-[#1D4F91] uppercase font-semibold mb-5">About BizinTokyo</p>
			<div class="h-[4px] w-[56px] bg-[#1D4F91] mx-auto mb-8" aria-hidden="true"></div>
			<h2 class="text-[32px] md:text-[44px] lg:text-[52px] font-bold text-[#1D4F91] leading-[1.25] max-w-3xl mx-auto tracking-[-0.02em]">
				東京のビジネスを、<br class="hidden md:block"/>世界へひらく。
			</h2>
			<p class="mt-10 text-[16px] md:text-[17px] text-[#1A1A1A] leading-[2.0] max-w-2xl mx-auto font-normal">
				BizinTokyoは、東京で開催されるビジネスイベントに参加する訪日トラベラーのための情報メディアです。<br class="hidden md:block"/>
				会場・アクセス・周辺ホテル・イベントガイドまで、現地で本当に役立つ情報を、日本語と英語の両方で発信しています。
			</p>
			<div class="mt-12">
				<a
					href="/contact"
					class="inline-flex items-center gap-3 bg-[#1D4F91] text-white px-9 py-4 text-[13px] font-semibold tracking-[0.12em] uppercase hover:bg-[#153A6B] transition-colors no-underline"
				>
					お問い合わせ <span aria-hidden="true">→</span>
				</a>
			</div>
		</div>
	</section>
</BaseLayout>
