---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { featuredArticles } from '../config/featured';
import { ARTICLE_CATEGORIES, t } from '../i18n';

const lang = 'ja';
const tr = t(lang);

const all = await getCollection('articles', (e) => e.data.lang === lang);
all.sort((a, b) => +b.data.date - +a.data.date);

const featured = featuredArticles
	.map((f) => all.find((a) => a.data.slug === f.slug && a.data.category === f.category))
	.filter((a): a is NonNullable<typeof a> => Boolean(a));

const sections = ARTICLE_CATEGORIES.map((c) => ({
	category: c,
	label: tr.categoryHeadings[c],
	items: all.filter((a) => a.data.category === c).slice(0, 4),
}));
---

<BaseLayout
	title="BizinTokyo - 東京のビジネスイベントを、もっと深く、もっとスマートに"
	description="訪日ビジネストラベラー・イベント参加者のための、東京ビジネスイベント情報メディア。会場・イベント・ホテル・ガイドを発信します。"
	lang={lang}
>
	<Hero lang={lang} />

	{featured.length > 0 && (
		<section class="max-w-[1200px] mx-auto px-6 py-20 md:py-28">
			<div class="flex items-end justify-between mb-10 border-b border-[#E5E5E5] pb-4">
				<div>
					<p class="text-[12px] tracking-[0.3em] text-[#6B6B6B] uppercase font-medium">{tr.meta.featured}</p>
					<h2 class="text-2xl md:text-3xl font-light text-[#1A1A1A] mt-2 tracking-tight">編集部のおすすめ</h2>
				</div>
			</div>
			<div class="grid md:grid-cols-2 gap-6 md:gap-8">
				{featured.map((a) => <ArticleCard article={a} size="large" />)}
			</div>
		</section>
	)}

	{sections.filter((s) => s.items.length > 0).map((s) => (
		<section class="max-w-[1200px] mx-auto px-6 py-16 md:py-20 border-t border-[#E5E5E5]">
			<div class="flex items-end justify-between mb-10">
				<div>
					<p class="text-[12px] tracking-[0.3em] text-[#6B6B6B] uppercase font-medium">{s.category}</p>
					<h2 class="text-2xl md:text-3xl font-light text-[#1A1A1A] mt-2 tracking-tight">{s.label}</h2>
				</div>
				<a href={`/${s.category}`} class="text-[13px] text-[#1A1A1A] hover:text-[#165E83] no-underline tracking-wide font-light">
					{tr.meta.viewAll} →
				</a>
			</div>
			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
				{s.items.map((a) => <ArticleCard article={a} />)}
			</div>
		</section>
	))}
</BaseLayout>
