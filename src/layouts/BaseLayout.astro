---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { Lang } from "../i18n";

interface Props {
	title: string;
	description: string;
	lang?: Lang;
	canonical?: string;
	ogImage?: string;
	articleData?: {
		headline: string;
		datePublished: string;
		dateModified?: string;
		image?: string;
		authorName?: string;
	};
	breadcrumb?: { name: string; href?: string }[];
}

const {
	title,
	description,
	lang = 'ja',
	canonical,
	ogImage = '/images/og/default-og.png',
	articleData,
	breadcrumb,
} = Astro.props;

const site = Astro.site?.toString().replace(/\/$/, '') || 'https://bizintokyo.com';
const url = canonical || new URL(Astro.url.pathname, site + '/').toString();
const ogImageUrl = ogImage && ogImage.startsWith('http')
	? ogImage
	: ogImage
		? `${site}${ogImage}`
		: `${site}/images/og/default-og.png`;

const path = Astro.url.pathname;
const isEnPath = path === '/en' || path.startsWith('/en/');
const jaPath = isEnPath ? (path === '/en' || path === '/en/' ? '/' : path.replace(/^\/en/, '')) : path;
const enPath = isEnPath ? path : (path === '/' ? '/en/' : `/en${path}`);

const jsonLdNodes = [];
jsonLdNodes.push({
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	url: site,
	name: 'BizinTokyo',
	inLanguage: lang === 'ja' ? 'ja-JP' : 'en-US',
});
jsonLdNodes.push({
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: 'Conec-tando, Inc.',
	url: 'https://www.conec-tando.com/',
});

if (articleData) {
	jsonLdNodes.push({
		'@context': 'https://schema.org',
		'@type': 'Article',
		headline: articleData.headline,
		datePublished: articleData.datePublished,
		dateModified: articleData.dateModified || articleData.datePublished,
		inLanguage: lang === 'ja' ? 'ja-JP' : 'en-US',
		image: articleData.image
			? articleData.image.startsWith('http')
				? articleData.image
				: `${site}${articleData.image}`
			: ogImageUrl,
		author: { '@type': 'Person', name: articleData.authorName || 'BizinTokyo Editorial Team' },
		publisher: {
			'@type': 'Organization',
			name: 'Conec-tando, Inc.',
			url: 'https://www.conec-tando.com/',
		},
	});
}

if (breadcrumb && breadcrumb.length > 0) {
	jsonLdNodes.push({
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: breadcrumb.map((b, i) => ({
			'@type': 'ListItem',
			position: i + 1,
			name: b.name,
			...(b.href ? { item: b.href.startsWith('http') ? b.href : `${site}${b.href}` } : {}),
		})),
	});
}
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="theme-color" content="#1D4F91" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={url} />

		<link rel="alternate" hreflang="ja" href={`${site}${jaPath}`} />
		<link rel="alternate" hreflang="en" href={`${site}${enPath}`} />
		<link rel="alternate" hreflang="x-default" href={`${site}${jaPath}`} />

		<meta property="og:type" content={articleData ? 'article' : 'website'} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={url} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:site_name" content="BizinTokyo" />
		<meta property="og:locale" content={lang === 'ja' ? 'ja_JP' : 'en_US'} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=Inter:wght@300;400;500;700&display=swap"
		/>

		<script type="application/ld+json" set:html={JSON.stringify(jsonLdNodes)} />
	</head>
	<body class="bg-white text-[#1A1A1A] font-sans font-normal min-h-screen flex flex-col antialiased text-[17px]">
		<Header lang={lang} />
		<main class="flex-1"><slot /></main>
		<Footer lang={lang} />
	</body>
</html>
