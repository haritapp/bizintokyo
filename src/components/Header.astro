---
import { t, CATEGORIES, type Lang } from '../i18n';

interface Props {
	lang?: Lang;
}
const { lang = 'ja' } = Astro.props;
const tr = t(lang);
const prefix = lang === 'en' ? '/en' : '';
const homeHref = prefix || '/';

const navLinks = CATEGORIES.map((c) => ({ href: `${prefix}/${c}`, label: tr.nav[c] }));
navLinks.push({ href: `${prefix}/contact`, label: tr.nav.contact });

const path = Astro.url.pathname;
const isEnPath = path === '/en' || path.startsWith('/en/');
const jaPath = isEnPath ? (path === '/en' || path === '/en/' ? '/' : path.replace(/^\/en/, '')) : path;
const enPath = isEnPath ? path : (path === '/' ? '/en/' : `/en${path}`);
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-[#E5E5E5]">
	<div class="h-[6px] bg-[#1D4F91]" aria-hidden="true"></div>
	<div class="max-w-[1200px] mx-auto px-6 py-4 flex items-center justify-between gap-6">
		<a href={homeHref} class="flex items-center no-underline" aria-label="BizinTokyo">
			<img
				src="/images/logo/bizintokyo-logo.svg"
				alt="BizinTokyo"
				class="h-10 md:h-12 w-auto block"
				width="500"
				height="400"
				loading="eager"
			/>
		</a>
		<nav class="hidden lg:flex items-center gap-7 text-[14px] text-[#1A1A1A] font-normal">
			{navLinks.map((link) => (
				<a href={link.href} class="hover:text-[#1D4F91] no-underline transition-colors">{link.label}</a>
			))}
		</nav>
		<div class="hidden lg:flex items-center gap-3 text-[13px] tracking-wider">
			<a href={jaPath} class={lang === 'ja' ? 'text-[#1D4F91] font-semibold' : 'text-[#6B6B6B] hover:text-[#1D4F91]'}>JA</a>
			<span class="text-[#E5E5E5]">|</span>
			<a href={enPath} class={lang === 'en' ? 'text-[#1D4F91] font-semibold' : 'text-[#6B6B6B] hover:text-[#1D4F91]'}>EN</a>
		</div>
		<button id="hamburger" class="lg:hidden text-2xl text-[#1A1A1A] leading-none font-light" aria-label="Menu">≡</button>
	</div>
	<nav id="mobile-menu" class="hidden lg:hidden border-t border-[#E5E5E5] bg-white">
		<div class="max-w-[1200px] mx-auto px-6 py-5 flex flex-col gap-3 text-[15px]">
			{navLinks.map((link) => (
				<a href={link.href} class="text-[#1A1A1A] hover:text-[#1D4F91] no-underline py-1.5">{link.label}</a>
			))}
			<div class="flex items-center gap-3 text-[13px] tracking-wider pt-3 border-t border-[#E5E5E5] mt-2">
				<a href={jaPath} class={lang === 'ja' ? 'text-[#1D4F91] font-semibold' : 'text-[#6B6B6B]'}>JA</a>
				<span class="text-[#E5E5E5]">|</span>
				<a href={enPath} class={lang === 'en' ? 'text-[#1D4F91] font-semibold' : 'text-[#6B6B6B]'}>EN</a>
			</div>
		</div>
	</nav>
</header>

<script>
	const btn = document.getElementById('hamburger');
	const menu = document.getElementById('mobile-menu');
	btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
