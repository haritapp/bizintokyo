---
interface Props {
	title: string;
	subtitle?: string;
	viewAll?: { href: string; label: string };
	align?: 'left' | 'center';
	invert?: boolean;
}
const { title, subtitle, viewAll, align = 'left', invert = false } = Astro.props;
const brand = invert ? '#FFFFFF' : '#1D4F91';
const brandBody = invert ? '#FFFFFF' : '#1D4F91';
const bodyText = invert ? '#FFFFFF' : '#1A1A1A';
---

<div class:list={[
	'flex items-end justify-between gap-6 mb-14 md:mb-16',
	align === 'center' ? 'flex-col items-center text-center' : '',
]}>
	<div class:list={[align === 'center' ? 'text-center' : '']}>
		{subtitle && (
			<p
				class="text-[13px] md:text-[14px] font-semibold uppercase tracking-[0.32em] mb-4"
				style={`color:${brand};`}
			>{subtitle}</p>
		)}
		<div
			class="h-[4px] w-[56px] mb-6"
			style={`background:${brand};` + (align === 'center' ? 'margin-left:auto;margin-right:auto;' : '')}
			aria-hidden="true"
		></div>
		<h2
			class="text-[32px] md:text-[44px] lg:text-[52px] font-bold leading-[1.15] tracking-[-0.02em]"
			style={`color:${brandBody};`}
		>{title}</h2>
	</div>
	{viewAll && (
		<a
			href={viewAll.href}
			class="text-[13px] tracking-[0.2em] uppercase font-semibold no-underline transition-colors whitespace-nowrap flex items-center gap-2.5 group"
			style={`color:${brand};`}
		>
			{viewAll.label}
			<span aria-hidden="true" class="inline-block w-2 h-2 rounded-full transition-transform group-hover:translate-x-1" style={`background:${brand};`}></span>
		</a>
	)}
</div>
