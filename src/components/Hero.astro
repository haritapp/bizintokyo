---
import { t, type Lang } from '../i18n';

interface Props {
	lang?: Lang;
}
const { lang = 'ja' } = Astro.props;
const tr = t(lang);
const prefix = lang === 'en' ? '/en' : '';
---

<section class="relative overflow-hidden bg-[#0A1F42]">
	<div
		class="absolute inset-0 bg-center bg-cover"
		style="background-image:url('/images/hero/hero-bg.svg');"
		aria-hidden="true"
	></div>
	<div class="absolute inset-0 bg-[#0A1F42]/35" aria-hidden="true"></div>

	<div class="relative max-w-[1200px] mx-auto px-6 py-24 md:py-32 lg:py-40 min-h-[70vh] lg:min-h-[75vh] flex items-center">
		<div class="max-w-4xl">
			<p class="text-[11px] md:text-[12px] tracking-[0.45em] text-white/80 font-semibold uppercase mb-7">
				Business Events in Tokyo
			</p>
			<h1 class="text-[36px] md:text-[56px] lg:text-[72px] font-bold leading-[1.1] tracking-[-0.02em] text-white">
				{lang === 'ja'
					? <>東京のビジネスイベントを、<br class="hidden md:block"/>もっと深く、もっとスマートに。</>
					: <>Tokyo's business events,<br class="hidden md:block"/>deeper and smarter.</>
				}
			</h1>
			<p class="mt-8 md:mt-10 text-[17px] md:text-[19px] text-white/85 leading-[1.75] font-normal max-w-2xl">
				{lang === 'ja'
					? '訪日ビジネストラベラー・イベント参加者のための、東京ビジネスイベント情報メディア。'
					: 'A Tokyo business-event media built for inbound business travelers and attendees.'}
			</p>
			<div class="mt-10 md:mt-12 flex flex-col sm:flex-row gap-4">
				<a
					href={`${prefix}/venue`}
					class="inline-flex items-center justify-center gap-2 bg-white text-[#1D4F91] px-8 py-4 text-[14px] font-semibold tracking-[0.08em] uppercase hover:bg-[#E8EEF7] transition-colors no-underline"
				>
					{lang === 'ja' ? '会場を探す' : 'Explore Venues'}
					<span aria-hidden="true">→</span>
				</a>
				<a
					href={`${prefix}/event`}
					class="inline-flex items-center justify-center gap-2 border border-white/80 text-white px-8 py-4 text-[14px] font-semibold tracking-[0.08em] uppercase hover:bg-white hover:text-[#1D4F91] transition-colors no-underline"
				>
					{lang === 'ja' ? 'イベントを見る' : 'Find Events'}
					<span aria-hidden="true">→</span>
				</a>
			</div>
		</div>
	</div>
</section>
