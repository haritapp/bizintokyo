---
import { t, type Lang } from '../i18n';

interface Props {
	lang?: Lang;
}
const { lang = 'ja' } = Astro.props;
const tr = t(lang);
const prefix = lang === 'en' ? '/en' : '';
---

<section class="relative overflow-hidden bg-[#FAFAF7]">
	<div
		class="absolute inset-0 bg-center bg-cover"
		style="background-image:url('/images/hero/hero-bg.svg');"
		aria-hidden="true"
	></div>
	<div class="absolute inset-0 bg-white/80" aria-hidden="true"></div>
	<div class="absolute top-0 left-0 h-full w-[3px] bg-[#1D4F91]" aria-hidden="true"></div>

	<div class="relative max-w-[1200px] mx-auto px-6 py-28 md:py-40 lg:py-48 min-h-[70vh] flex items-center">
		<div class="max-w-3xl">
			<p class="text-[11px] md:text-[12px] tracking-[0.4em] text-[#1D4F91] font-medium uppercase mb-8">
				Business Events in Tokyo
			</p>
			<h1 class="text-[40px] md:text-[56px] lg:text-[64px] font-light leading-[1.15] tracking-[-0.02em] text-[#1A1A1A]">
				{tr.tagline}
			</h1>
			<p class="mt-10 text-[17px] md:text-[18px] text-[#1A1A1A] leading-[1.8] font-normal max-w-2xl">
				{tr.subTagline}
			</p>
			<div class="mt-12 flex flex-col sm:flex-row gap-4">
				<a href={`${prefix}/venue`} class="btn-brand">
					{lang === 'ja' ? '会場を見る' : 'Explore Venues'}
					<span aria-hidden="true">→</span>
				</a>
				<a href={`${prefix}/event`} class="btn-outline">
					{lang === 'ja' ? 'イベントを探す' : 'Find Events'}
					<span aria-hidden="true">→</span>
				</a>
			</div>
		</div>
	</div>

	<div class="relative border-t border-[#E5E5E5] bg-white/70 backdrop-blur-sm">
		<div class="max-w-[1200px] mx-auto px-6 py-4 flex flex-wrap items-center gap-x-8 gap-y-2 text-[12px] tracking-[0.2em] text-[#6B6B6B] uppercase">
			<span class="text-[#1D4F91] font-medium">{lang === 'ja' ? '東京 TOKYO' : 'TOKYO'}</span>
			<span>{lang === 'ja' ? 'Venues · 会場' : 'Venues'}</span>
			<span class="text-[#E5E5E5]">·</span>
			<span>{lang === 'ja' ? 'Events · イベント' : 'Events'}</span>
			<span class="text-[#E5E5E5]">·</span>
			<span>{lang === 'ja' ? 'Hotels · ホテル' : 'Hotels'}</span>
			<span class="text-[#E5E5E5]">·</span>
			<span>{lang === 'ja' ? 'Guides · ガイド' : 'Guides'}</span>
		</div>
	</div>
</section>
