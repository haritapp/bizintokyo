---
import { t, type Lang } from '../i18n';

interface Props {
	current: number;
	total: number;
	baseHref: string; // e.g. "/venue" — links: /venue (page1), /venue/page/2 ...
	lang?: Lang;
}

const { current, total, baseHref, lang = 'ja' } = Astro.props;
const tr = t(lang);

if (total <= 1) {
	// Render nothing
}

const hrefFor = (page: number) => (page === 1 ? `${baseHref}/` : `${baseHref}/page/${page}`);

const pages: number[] = [];
for (let p = 1; p <= total; p++) pages.push(p);
---

{total > 1 && (
	<nav class="flex items-center justify-center gap-2 mt-12 text-[13px] font-light tracking-wide" aria-label="Pagination">
		{current > 1 ? (
			<a href={hrefFor(current - 1)} class="px-3 py-2 text-[#1A1A1A] hover:text-[#1D4F91] no-underline">‹ {tr.meta.prev}</a>
		) : (
			<span class="px-3 py-2 text-[#E5E5E5]">‹ {tr.meta.prev}</span>
		)}
		{pages.map((p) => (
			<a
				href={hrefFor(p)}
				class={`px-3 py-2 no-underline ${p === current ? 'text-[#1D4F91] border-b border-[#1D4F91]' : 'text-[#1A1A1A] hover:text-[#1D4F91]'}`}
			>{p}</a>
		))}
		{current < total ? (
			<a href={hrefFor(current + 1)} class="px-3 py-2 text-[#1A1A1A] hover:text-[#1D4F91] no-underline">{tr.meta.next} ›</a>
		) : (
			<span class="px-3 py-2 text-[#E5E5E5]">{tr.meta.next} ›</span>
		)}
	</nav>
)}
