---
import type { CollectionEntry } from 'astro:content';

interface Props {
	slides: CollectionEntry<'articles'>[];
}

const { slides } = Astro.props;
---

<div class="relative aspect-[16/7] overflow-hidden bg-gray-100" id="hero-slider">
	{slides.map((slide, i) => {
		const prefix = slide.data.lang === 'en' ? '/en' : '';
		const href = `${prefix}/${slide.data.category}/${slide.data.slug}`;
		return (
			<a
				href={href}
				class={`hero-slide absolute inset-0 transition-opacity duration-700 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
				data-index={i}
			>
				<div class="absolute inset-0 bg-gradient-to-br from-brand to-blue-400">
					{slide.data.image && <img src={slide.data.image} alt={slide.data.title} class="w-full h-full object-cover" />}
				</div>
				<div class="absolute inset-0 bg-black/30"></div>
				<div class="absolute bottom-0 left-0 right-0 p-6 md:p-10 text-white">
					<span class="inline-block bg-brand text-xs px-2 py-1 rounded mb-2">{slide.data.category}</span>
					<h2 class="text-2xl md:text-4xl font-bold line-clamp-2">{slide.data.title}</h2>
				</div>
			</a>
		);
	})}
	{slides.length > 1 && (
		<>
			<button id="hero-prev" class="absolute left-4 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white w-10 h-10 rounded-full flex items-center justify-center text-xl" aria-label="Previous">‹</button>
			<button id="hero-next" class="absolute right-4 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white w-10 h-10 rounded-full flex items-center justify-center text-xl" aria-label="Next">›</button>
			<button id="hero-pause" class="absolute right-4 bottom-4 bg-white/80 hover:bg-white px-3 py-1 text-xs rounded" aria-label="Pause">❚❚</button>
		</>
	)}
</div>

<script>
	const slider = document.getElementById('hero-slider');
	if (slider) {
		const slides = Array.from(slider.querySelectorAll('.hero-slide')) as HTMLElement[];
		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		let current = 0;
		let timer: number | undefined;
		let paused = reduced;

		function show(i: number) {
			slides.forEach((s, idx) => (s.style.opacity = idx === i ? '1' : '0'));
			current = i;
		}
		function next() { show((current + 1) % slides.length); }
		function prev() { show((current - 1 + slides.length) % slides.length); }
		function start() {
			if (paused || slides.length <= 1) return;
			timer = window.setInterval(next, 5000);
		}
		function stop() { if (timer) window.clearInterval(timer); timer = undefined; }

		document.getElementById('hero-prev')?.addEventListener('click', (e) => { e.preventDefault(); stop(); prev(); start(); });
		document.getElementById('hero-next')?.addEventListener('click', (e) => { e.preventDefault(); stop(); next(); start(); });
		document.getElementById('hero-pause')?.addEventListener('click', (e) => {
			e.preventDefault();
			paused = !paused;
			if (paused) stop(); else start();
		});

		start();
	}
</script>
