---
import type { CollectionEntry } from 'astro:content';
import { t } from '../i18n';

interface Props {
	article: CollectionEntry<'articles'>;
	size?: 'default' | 'large';
}

const { article, size = 'default' } = Astro.props;
const { title, date, category, slug, lang, heroImage, ogImage, isPR, description } = article.data;

const prefix = lang === 'en' ? '/en' : '';
const href = `${prefix}/${category}/${slug}`;

const d = new Date(date);
const formattedDate = `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;

const tr = t(lang);
const categoryLabel = (tr.categoryHeadings as Record<string, string>)[category] ?? category;
const image = heroImage || ogImage || '';
---

<a
	href={href}
	class={`group block bg-white border border-[#E5E5E5] overflow-hidden transition hover:border-[#165E83] no-underline ${size === 'large' ? 'md:flex' : ''}`}
>
	<div class={`aspect-video bg-[#FAFAF7] overflow-hidden ${size === 'large' ? 'md:w-1/2 md:aspect-auto' : ''}`}>
		{image ? (
			<img src={image} alt={title} loading="lazy" class="w-full h-full object-cover transition duration-500 group-hover:scale-[1.03]" />
		) : (
			<div class="w-full h-full flex items-center justify-center text-[#6B6B6B] text-xs tracking-widest font-light">{categoryLabel.toUpperCase()}</div>
		)}
	</div>
	<div class={`p-5 ${size === 'large' ? 'md:w-1/2 md:p-8 md:flex md:flex-col md:justify-center' : ''}`}>
		<div class="text-[12px] text-[#6B6B6B] tracking-wider font-light mb-3">
			<span class="text-[#165E83]">{categoryLabel}</span>
			<span class="mx-2">·</span>
			<time>{formattedDate}</time>
			{isPR && <span class="ml-2 inline-block px-1.5 py-0.5 border border-[#E5E5E5] text-[10px]">PR</span>}
		</div>
		<h3 class={`${size === 'large' ? 'text-xl md:text-2xl' : 'text-base'} font-normal text-[#1A1A1A] leading-snug mb-3 transition group-hover:text-[#165E83]`}>{title}</h3>
		{description && (
			<p class="text-[13px] text-[#6B6B6B] leading-relaxed line-clamp-2 font-light">{description}</p>
		)}
		<div class="mt-4 text-[13px] text-[#1A1A1A] font-light tracking-wide group-hover:text-[#165E83] transition">
			{lang === 'ja' ? '読む' : 'Read'} →
		</div>
	</div>
</a>
