---
import type { CollectionEntry } from 'astro:content';

interface Props {
	article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { title, date, category, slug, lang, image, isPR } = article.data;

const prefix = lang === 'en' ? '/en' : '';
const href = `${prefix}/${category}/${slug}`;

const formattedDate = date.toISOString().slice(0, 10).replace(/-/g, '/');

const categoryLabels: Record<string, { ja: string; en: string }> = {
	venue: { ja: '会場', en: 'Venue' },
	event: { ja: 'イベント', en: 'Event' },
	eventguide: { ja: 'イベントガイド', en: 'Guide' },
	news: { ja: 'ニュース', en: 'News' },
	column: { ja: 'コラム', en: 'Column' },
};
const categoryLabel = categoryLabels[category][lang];
---

<a href={href} class="group block bg-white border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition">
	<div class="aspect-video bg-gradient-to-br from-brand to-blue-400 relative">
		{image && <img src={image} alt={title} class="w-full h-full object-cover" />}
		<div class="absolute top-2 left-2 flex gap-2">
			<span class="bg-brand text-white text-xs px-2 py-1 rounded">{categoryLabel}</span>
			{isPR && <span class="bg-yellow-500 text-white text-xs px-2 py-1 rounded">PR</span>}
		</div>
	</div>
	<div class="p-4">
		<div class="text-xs text-gray-500 mb-1">{formattedDate}</div>
		<h3 class="text-base font-bold line-clamp-2 group-hover:text-brand">{title}</h3>
	</div>
</a>
