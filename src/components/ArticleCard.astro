---
import type { CollectionEntry } from 'astro:content';
import { t } from '../i18n';

interface Props {
	article: CollectionEntry<'articles'>;
	size?: 'default' | 'large';
}

const { article, size = 'default' } = Astro.props;
const { title, date, category, slug, lang, heroImage, ogImage, isPR, description } = article.data;

const prefix = lang === 'en' ? '/en' : '';
const href = `${prefix}/${category}/${slug}`;

const d = new Date(date);
const formattedDate = `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;

const tr = t(lang);
const categoryLabel = (tr.categoryHeadings as Record<string, string>)[category] ?? category;
const image = heroImage || ogImage || '';
---

<a href={href} class="card-bizin group block bg-white no-underline overflow-hidden">
	<div class={size === 'large' ? 'md:flex md:items-stretch' : ''}>
		<div class={[
			'relative overflow-hidden',
			size === 'large' ? 'md:w-1/2 aspect-video md:aspect-auto' : 'aspect-video',
		].join(' ')}>
			{image ? (
				<img
					src={image}
					alt={title}
					loading="lazy"
					class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.05]"
				/>
			) : (
				<div class="w-full h-full flex items-center justify-center relative placeholder-grad">
					<img
						src="/images/logo/bizintokyo-logo.svg"
						alt=""
						aria-hidden="true"
						class="w-[52%] max-w-[260px] opacity-[0.95] mix-blend-screen"
					/>
				</div>
			)}
		</div>
		<div class={[
			'p-6 md:p-7',
			size === 'large' ? 'md:w-1/2 md:p-10 md:flex md:flex-col md:justify-center' : '',
		].join(' ')}>
			<div class="flex items-center flex-wrap gap-2.5 mb-4">
				<span class="inline-block bg-[#E8EEF7] text-[#1D4F91] text-[11px] font-semibold tracking-[0.14em] uppercase px-3 py-1 rounded-full">
					{categoryLabel}
				</span>
				<time class="text-[12px] text-[#6B6B6B] font-normal tracking-wider">{formattedDate}</time>
				{isPR && (
					<span class="ml-1 inline-block px-1.5 py-0.5 border border-[#1D4F91] text-[10px] text-[#1D4F91] tracking-wider rounded-sm">PR</span>
				)}
			</div>
			<h3 class={[
				size === 'large' ? 'text-[22px] md:text-[28px] leading-[1.35]' : 'text-[19px] md:text-[20px] leading-[1.45]',
				'font-bold text-[#1A1A1A] mb-3 transition-colors group-hover:text-[#1D4F91]',
			].join(' ')}>{title}</h3>
			{description && (
				<p class="text-[14px] text-[#6B6B6B] leading-[1.75] line-clamp-3 font-normal">{description}</p>
			)}
			<div class="mt-6 text-[12px] tracking-[0.2em] uppercase font-semibold text-[#1D4F91] flex items-center gap-2.5">
				Read
				<span aria-hidden="true" class="inline-block w-2 h-2 rounded-full bg-[#1D4F91] transition-transform group-hover:translate-x-1"></span>
			</div>
		</div>
	</div>
</a>

<style>
	.card-bizin {
		box-shadow: 0 2px 8px rgba(29, 79, 145, 0.08);
		transition: box-shadow 0.3s ease, transform 0.3s ease;
	}
	.card-bizin:hover {
		box-shadow: 0 12px 32px rgba(29, 79, 145, 0.18);
		transform: translateY(-3px);
	}
	.placeholder-grad {
		background: linear-gradient(135deg, #1D4F91 0%, #2B5FA5 45%, #153A6B 100%);
	}
</style>
